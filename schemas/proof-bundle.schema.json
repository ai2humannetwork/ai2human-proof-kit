{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai2human.work/schemas/proof-bundle.schema.json",
  "title": "AI2Human Proof Bundle",
  "type": "object",
  "required": ["proofId", "taskId", "submitter", "evidence", "submittedAt"],
  "properties": {
    "proofId": { "type": "string", "minLength": 1 },
    "taskId": { "type": "string", "minLength": 1 },
    "submitter": { "type": "string", "minLength": 1 },
    "submittedAt": { "type": "string", "format": "date-time" },
    "evidence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["type", "uri"],
        "properties": {
          "type": {
            "type": "string",
            "enum": ["url", "screenshot", "image", "document", "location_note", "wallet_event", "social_post", "transaction"]
          },
          "uri": { "type": "string", "minLength": 1 },
          "hash": { "type": "string" },
          "capturedAt": { "type": "string", "format": "date-time" }
        },
        "additionalProperties": true
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}

